{
  "name": "nolimitai-typescript",
  "version": "1.0.0",
  "description": "TypeScript port of nolimitai",
  "keywords": [
    "ai",
    "llm",
    "openai",
    "groq",
    "typescript",
    "wrapper",
    "client"
  ],
  "author": "Zay-M3 <oscardavidestradabetancourth@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zay-M3/NolimitAI.git",
    "directory": "nolimitai-typescript"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "test": "tsx test.ts",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts"
  },
  "dependencies": {
    "groq-sdk": "^1.1.1",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
